{
  "name": "review-syndrome",
  "version": "1.0.0",
  "description": "Autonomous AI agent that fixes bugs from Azure DevOps work items and creates PRs",
  "type": "module",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "npm run build && func start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@azure/functions": "^4.5.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^20.0.0",
    "azure-functions-core-tools": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
